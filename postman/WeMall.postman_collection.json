                  "mode": "graphql",
                  "graphql": {
                    "query": "mutation BuyerVerifyOTP($phone: String!, $otp: String!) { buyerVerifyOTP(phone: $phone, otp: $otp) { accessToken refreshToken user { id email phone fullName role isVerified } } }",
                    "variables": "{\n  \"phone\": \"{{buyerPhone}}\",\n  \"otp\": \"{{buyerOtp}}\"\n}"
