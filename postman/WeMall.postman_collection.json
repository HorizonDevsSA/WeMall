                ],
                "body": {
                  "mode": "graphql",
                  "graphql": {
                    "query": "mutation BuyerSendOTP($phone: String!) { buyerSendOTP(phone: $phone) { message requestId } }",
                    "variables": "{\n  \"phone\": \"{{buyerPhone}}\"\n}"
